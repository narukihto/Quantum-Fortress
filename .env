# --- Network Configuration ---
# This matches the internal port 3000 in your Rust code
SERVER_PORT=3000

# --- Security & Logic Settings ---
# Shannon Entropy threshold (Aligned with handlers.rs)
MIN_ENTROPY=4.5

# --- Resource Constraints ---
# These match the values in your docker-compose.yml
CPU_LIMIT=0.50
MEMORY_LIMIT=512M

# --- Runtime Logging ---
# Valid levels: error, warn, info, debug, trace
RUST_LOG=info
