# Network Configuration
# This matches the port used in main.rs and tests.py
SERVER_PORT=3000

# Security Thresholds
# Minimum Shannon Entropy required (aligned with handlers.rs)
MIN_ENTROPY=4.5

# Resource Management (for Docker Compose)
CPU_LIMIT=0.50
MEMORY_LIMIT=512M

# Logging Level
# Options: error, warn, info, debug, trace
RUST_LOG=info
